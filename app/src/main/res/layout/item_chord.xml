<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="236dp"
    android:layout_margin="7dp"
    android:background="@drawable/chord_card_background"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    android:orientation="vertical"
    android:padding="14dp">

    <com.example.chordlab.chordlibrary.view.ChordDiagramView
        android:id="@+id/chordDiagramView"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:background="@drawable/chord_diagram_background" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/chordNameTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/chord_dark_teal"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/favoriteTextView"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:textColor="@color/chord_orange"
            android:textSize="28sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/chordTypeTextView"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/chord_level_badge_background"
        android:gravity="center"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="@color/chord_dark_teal"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="end"
        android:text="Learn →"
        android:textColor="@color/chord_teal"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
