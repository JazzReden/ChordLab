<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="7dp"
    android:background="@drawable/chord_card_background"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    android:minHeight="248dp"
    android:orientation="vertical"
    android:padding="14dp">

    <com.example.chordlab.common.view.FretboardView
        android:id="@+id/scaleMiniFretboardView"
        android:layout_width="match_parent"
        android:layout_height="128dp"
        android:background="@drawable/chord_diagram_background" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/scaleNameTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/chord_dark_teal"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/scaleFavoriteTextView"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="@string/scale_favorite_content_description"
            android:gravity="center"
            android:textColor="@color/chord_orange"
            android:textSize="26sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/scaleRatingTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:contentDescription="@string/scale_rating_content_description"
        android:letterSpacing="0.08"
        android:maxLines="1"
        android:textColor="@color/chord_orange"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/scaleDifficultyTextView"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:minWidth="72dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/chord_dark_teal"
            android:textSize="11sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/practiceScaleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:maxLines="1"
            android:text="Practice →"
            android:textColor="@color/chord_teal"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
