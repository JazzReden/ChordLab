<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/chord_screen_background"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="38dp"
    android:paddingEnd="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="♪ Library"
            android:textColor="@color/chord_dark_teal"
            android:textSize="32sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/chordDashboardButton"
            android:layout_width="118dp"
            android:layout_height="44dp"
            android:background="@drawable/primary_button_background"
            android:backgroundTint="@color/chord_teal"
            android:text="Back"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <EditText
        android:id="@+id/searchChordEditText"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="22dp"
        android:background="@drawable/chord_search_background"
        android:hint="Search chords..."
        android:inputType="text"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:singleLine="true"
        android:textColor="@color/chord_dark_teal"
        android:textColorHint="#8AA7A3"
        android:textSize="16sp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/chordFilterLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />

    </HorizontalScrollView>

    <TextView
        android:id="@+id/emptyChordTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:gravity="center"
        android:text="No chords found"
        android:textColor="@color/chord_dark_teal"
        android:textSize="16sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chordRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="22dp" />

</LinearLayout>
