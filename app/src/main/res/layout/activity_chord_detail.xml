<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/chord_screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="38dp"
        android:paddingEnd="22dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/backToChordListButton"
                android:layout_width="104dp"
                android:layout_height="44dp"
                android:background="@drawable/chord_filter_pill_background"
                android:backgroundTint="@color/chord_soft_green"
                android:text="← Back"
                android:textAllCaps="false"
                android:textColor="@color/chord_dark_teal"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />



        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/chord_card_background"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:id="@+id/detailChordNameTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/chord_dark_teal"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detailChordTypeTextView"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/chord_level_badge_background"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/chord_dark_teal"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.example.chordlab.chordlibrary.view.ChordDiagramView
                android:id="@+id/detailChordDiagramView"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/chord_diagram_background" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Finger Position"
                android:textColor="@color/chord_dark_teal"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detailFingerPlacementTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#5C6B67"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="String Indicators"
                android:textColor="@color/chord_dark_teal"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detailStringIndicatorsTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#5C6B67"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Beginner Note"
                android:textColor="@color/chord_dark_teal"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detailDescriptionTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#5C6B67"
                android:textSize="15sp" />

            <Button
                android:id="@+id/detailFavoriteButton"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/primary_button_background"
                android:backgroundTint="@color/chord_teal"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/detailDeleteFavoriteButton"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/chord_filter_pill_background"
                android:backgroundTint="@color/chord_soft_green"
                android:text="Delete from Favorites"
                android:textAllCaps="false"
                android:textColor="@color/chord_dark_teal"
                android:textSize="17sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
